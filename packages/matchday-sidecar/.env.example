# Matchday sidecar — copy to .env and fill in. The .env is gitignored.

# Wallet seed (one mnemonic controls USDT on Arbitrum, TON and TRON).
MATCHDAY_SEED="your twelve or twenty four word mnemonic here"

# Arbitrum One RPC (defaults to the public endpoint if unset).
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc

# TON access (optional but recommended to avoid public rate limits).
TON_TONCENTER_KEY=
TON_TONAPI_KEY=

# TRON GasFree credentials (optional; only needed to pay on TRON).
GASFREE_API_KEY=
GASFREE_API_SECRET=

# Deployed on-chain guard to surface in /policy (defaults to the published deployment).
GUARD_ADDRESS=0x92891C2E97E2285F9DAc5cCdD0844f1D9c9De44e
GUARD_OWNER=0xa5a35C55aE15934a7476C3c9BDbdBB7a2d56f261

# HTTP port (default 8787).
PORT=8787
